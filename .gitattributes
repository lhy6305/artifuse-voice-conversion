# Normalize text files by default.
* text=auto

# Keep common source and metadata files as text.
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.bat text eol=crlf

# Treat generated payloads and media as binary if they are ever added by mistake.
*.pt binary
*.pth binary
*.ckpt binary
*.onnx binary
*.npy binary
*.npz binary
*.pkl binary
*.pickle binary
*.db binary
*.sqlite binary
*.sqlite3 binary
*.wav binary
*.mp3 binary
*.flac binary
*.ogg binary
*.m4a binary
*.aac binary
*.wma binary
*.opus binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.gz binary
*.tar binary
*.tgz binary
*.xz binary
*.rar binary
*.exe binary
*.dll binary
