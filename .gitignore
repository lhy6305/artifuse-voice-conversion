# Reports retention policy for repo rebuilds:
# keep recovery metadata and selected checkpoints,
# exclude reproducible package payloads and heavy local caches
reports/training/**
!reports/training/
!reports/training/**/
!reports/training/**/*.train_plan.json
!reports/training/**/*.train_plan.md
!reports/training/**/*.summary.json
!reports/training/**/*.summary.md
!reports/training/**/checkpoints/
!reports/training/**/checkpoints/*.pt

reports/runtime/**
!reports/runtime/
!reports/runtime/**/
