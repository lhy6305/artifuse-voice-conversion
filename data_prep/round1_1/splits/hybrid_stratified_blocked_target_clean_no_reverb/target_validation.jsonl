{"record_id":"target::chapter3_2_firefly_178","dataset":"firefly_round1_mainstream","role":"target","split":"train","audio_path":"F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter3_2_firefly_178.wav","audio":{"sample_rate":44100,"channels":1,"sample_width_bytes":2,"duration_sec":13.829977},"text":{"raw":"据说，苏乐达起源于监狱时期流行的甜味药水，由苏萨先生发明，因此得名苏萨水。后来星际行商艾迪恩发现其中商机，便买下了苏萨水的配方。","clean":"据说，苏乐达起源于监狱时期流行的甜味药水，由苏萨先生发明，因此得名苏萨水。后来星际行商艾迪恩发现其中商机，便买下了苏萨水的配方。","cleaned_lab_path":"F:/proj_dev/tmp/workdir4/data_prep/round1_1/firefly_mainstream/labels/chapter3_2_firefly_178.lab"},"labels":{"has_text":true,"text_is_runtime_required":false},"source_metadata":{"prepared_wav_path":null,"original_lab_path":"chapter3_2_firefly_178.lab","cleaning_kept_punctuation":["。","，"],"cleaning_removed_symbols":[]}}
{"record_id":"target::chapter4_7_firefly_119","dataset":"firefly_round1_mainstream","role":"target","split":"train","audio_path":"F:/proj_dev/tmp/workdir4/data_prep/round1_1/firefly_mainstream/audio/chapter4_7_firefly_119.wav","audio":{"sample_rate":44100,"channels":1,"sample_width_bytes":2,"duration_sec":14.770998},"text":{"raw":"真是值得期待的一天。两个人——不再是共犯，只是在银河间漂泊的两个灵魂——普普通通地相见，普普通通地相识……","clean":"真是值得期待的一天。两个人，不再是共犯，只是在银河间漂泊的两个灵魂，普普通通地相见，普普通通地相识，","cleaned_lab_path":"F:/proj_dev/tmp/workdir4/data_prep/round1_1/firefly_mainstream/labels/chapter4_7_firefly_119.lab"},"labels":{"has_text":true,"text_is_runtime_required":false},"source_metadata":{"prepared_wav_path":"audio/chapter4_7_firefly_119.wav","original_lab_path":"chapter4_7_firefly_119.lab","cleaning_kept_punctuation":["。","，"],"cleaning_removed_symbols":[]}}
{"record_id":"target::chapter3_17_firefly_129","dataset":"firefly_round1_mainstream","role":"target","split":"train","audio_path":"F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter3_17_firefly_129.wav","audio":{"sample_rate":44100,"channels":1,"sample_width_bytes":2,"duration_sec":15.477982},"text":{"raw":"我果然还活着，且如我所想——抵达了与「美梦」截然不同的地方。匹诺康尼的梦境下埋藏着另一片更原始，也更混沌的忆域，它的名字是…「流放之地」。","clean":"我果然还活着，且如我所想，抵达了与美梦截然不同的地方。匹诺康尼的梦境下埋藏着另一片更原始，也更混沌的忆域，它的名字是，流放之地。","cleaned_lab_path":"F:/proj_dev/tmp/workdir4/data_prep/round1_1/firefly_mainstream/labels/chapter3_17_firefly_129.lab"},"labels":{"has_text":true,"text_is_runtime_required":false},"source_metadata":{"prepared_wav_path":null,"original_lab_path":"chapter3_17_firefly_129.lab","cleaning_kept_punctuation":["。","，"],"cleaning_removed_symbols":["「","」"]}}
