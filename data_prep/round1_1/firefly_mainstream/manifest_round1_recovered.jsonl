{"id": "chapter4_7_firefly_111", "wav_path": "chapter4_7_firefly_111.wav", "original_lab_path": "chapter4_7_firefly_111.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_111.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 44100, "frame_count": 270201, "duration_sec": 6.127007, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "这样吗…这一次同行，也会迎来戛然而止的时刻吗？", "cleaned": "这样吗，这一次同行，也会迎来戛然而止的时刻吗？", "kept_punctuation": ["，", "？"], "removed_symbols": [], "normalized_symbols": [{"from": "…", "to": "，"}]}, "include_in_round1": true, "exclusion_reasons": [], "prepared_wav_path": "audio/chapter4_7_firefly_111.wav", "round1_1_recovery": {"source_wav_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter4_7_firefly_111.wav", "source_sample_rate": 48000, "source_channels": 1, "target_sample_rate": 44100, "target_channels": 1, "recovery_mode": "lexical_format_normalization"}}
