{"id": "chapter4_7_firefly_115", "wav_path": "chapter4_7_firefly_115.wav", "original_lab_path": "chapter4_7_firefly_115.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_115.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 44100, "frame_count": 244005, "duration_sec": 5.532993, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "嗯…不必说什么，你的眼睛已经给了我答案。", "cleaned": "嗯，不必说什么，你的眼睛已经给了我答案。", "kept_punctuation": ["。", "，"], "removed_symbols": [], "normalized_symbols": [{"from": "…", "to": "，"}]}, "include_in_round1": true, "exclusion_reasons": [], "prepared_wav_path": "audio/chapter4_7_firefly_115.wav", "round1_1_recovery": {"source_wav_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter4_7_firefly_115.wav", "source_sample_rate": 48000, "source_channels": 1, "target_sample_rate": 44100, "target_channels": 1, "recovery_mode": "lexical_format_normalization"}}
{"id": "chapter4_7_firefly_116", "wav_path": "chapter4_7_firefly_116.wav", "original_lab_path": "chapter4_7_firefly_116.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_116.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 44100, "frame_count": 462653, "duration_sec": 10.490998, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "我会努力忘记这件事，把它封藏进脑海深处…等到分别的那一天，我会把你的话当作重聚的约定。", "cleaned": "我会努力忘记这件事，把它封藏进脑海深处，等到分别的那一天，我会把你的话当作重聚的约定。", "kept_punctuation": ["。", "，"], "removed_symbols": [], "normalized_symbols": [{"from": "…", "to": "，"}]}, "include_in_round1": true, "exclusion_reasons": [], "prepared_wav_path": "audio/chapter4_7_firefly_116.wav", "round1_1_recovery": {"source_wav_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter4_7_firefly_116.wav", "source_sample_rate": 48000, "source_channels": 1, "target_sample_rate": 44100, "target_channels": 1, "recovery_mode": "lexical_format_normalization"}}
