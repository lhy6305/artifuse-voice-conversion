{"record_id": "target::chapter3_17_firefly_145", "dataset": "firefly_round1_mainstream", "role": "target", "split": "train", "audio_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter3_17_firefly_145.wav", "audio": {"sample_rate": 44100, "channels": 1, "sample_width_bytes": 2, "duration_sec": 9.487982}, "text": {"raw": "除此以外…是我的私心。我想以「流萤」…而非「萨姆」的身份和你们同行。", "clean": "除此以外，是我的私心。我想以流萤，而非萨姆的身份和你们同行。", "cleaned_lab_path": "F:/proj_dev/tmp/workdir4/data_prep/round1/firefly_mainstream/labels/chapter3_17_firefly_145.lab"}, "labels": {"has_text": true, "text_is_runtime_required": false}, "source_metadata": {"original_lab_path": "chapter3_17_firefly_145.lab", "cleaning_kept_punctuation": ["。", "，"], "cleaning_removed_symbols": ["「", "」"]}}
{"record_id": "target::chapter3_30_firefly_153", "dataset": "firefly_round1_mainstream", "role": "target", "split": "train", "audio_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter3_30_firefly_153.wav", "audio": {"sample_rate": 44100, "channels": 1, "sample_width_bytes": 2, "duration_sec": 9.771995}, "text": {"raw": "分享给你一句话吧，其实是黄泉小姐告诉我的，她说「所谓的不可能之事，只是尚未到来之事」……", "clean": "分享给你一句话吧，其实是黄泉小姐告诉我的，她说所谓的不可能之事，只是尚未到来之事，", "cleaned_lab_path": "F:/proj_dev/tmp/workdir4/data_prep/round1/firefly_mainstream/labels/chapter3_30_firefly_153.lab"}, "labels": {"has_text": true, "text_is_runtime_required": false}, "source_metadata": {"original_lab_path": "chapter3_30_firefly_153.lab", "cleaning_kept_punctuation": ["，"], "cleaning_removed_symbols": ["「", "」"]}}
{"record_id": "target::chapter3_30_firefly_133", "dataset": "firefly_round1_mainstream", "role": "target", "split": "train", "audio_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter3_30_firefly_133.wav", "audio": {"sample_rate": 44100, "channels": 1, "sample_width_bytes": 2, "duration_sec": 10.324989}, "text": {"raw": "既然你会出现在这…那我就长话短说吧。大约半小时前，我收到未知发信人的消息，就立刻赶过来了。", "clean": "既然你会出现在这，那我就长话短说吧。大约半小时前，我收到未知发信人的消息，就立刻赶过来了。", "cleaned_lab_path": "F:/proj_dev/tmp/workdir4/data_prep/round1/firefly_mainstream/labels/chapter3_30_firefly_133.lab"}, "labels": {"has_text": true, "text_is_runtime_required": false}, "source_metadata": {"original_lab_path": "chapter3_30_firefly_133.lab", "cleaning_kept_punctuation": ["。", "，"], "cleaning_removed_symbols": []}}
{"record_id": "target::chapter3_30_firefly_126", "dataset": "firefly_round1_mainstream", "role": "target", "split": "train", "audio_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter3_30_firefly_126.wav", "audio": {"sample_rate": 44100, "channels": 1, "sample_width_bytes": 2, "duration_sec": 10.865986}, "text": {"raw": "对我来说，「隐瞒」远比「坦诚」更简单…但我也想试试，自己能否像普通人一样表达心声……", "clean": "对我来说，隐瞒远比坦诚更简单，但我也想试试，自己能否像普通人一样表达心声，", "cleaned_lab_path": "F:/proj_dev/tmp/workdir4/data_prep/round1/firefly_mainstream/labels/chapter3_30_firefly_126.lab"}, "labels": {"has_text": true, "text_is_runtime_required": false}, "source_metadata": {"original_lab_path": "chapter3_30_firefly_126.lab", "cleaning_kept_punctuation": ["，"], "cleaning_removed_symbols": ["「", "」"]}}
{"record_id": "target::chapter3_17_firefly_127", "dataset": "firefly_round1_mainstream", "role": "target", "split": "train", "audio_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter3_17_firefly_127.wav", "audio": {"sample_rate": 44100, "channels": 1, "sample_width_bytes": 2, "duration_sec": 11.305986}, "text": {"raw": "就像你看到的，我被「死亡」的翼刃贯穿。浓稠忆质的重压…它们在脑海中炸开，恍若现实。", "clean": "就像你看到的，我被死亡的翼刃贯穿。浓稠忆质的重压，它们在脑海中炸开，恍若现实。", "cleaned_lab_path": "F:/proj_dev/tmp/workdir4/data_prep/round1/firefly_mainstream/labels/chapter3_17_firefly_127.lab"}, "labels": {"has_text": true, "text_is_runtime_required": false}, "source_metadata": {"original_lab_path": "chapter3_17_firefly_127.lab", "cleaning_kept_punctuation": ["。", "，"], "cleaning_removed_symbols": ["「", "」"]}}
{"record_id": "target::chapter3_3_firefly_111", "dataset": "firefly_round1_mainstream", "role": "target", "split": "train", "audio_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter3_3_firefly_111.wav", "audio": {"sample_rate": 44100, "channels": 1, "sample_width_bytes": 2, "duration_sec": 11.704989}, "text": {"raw": "我想再带你去个地方，可以吗？这次不是什么旅游景点，恰恰相反…大概算是我的「秘密据点」。", "clean": "我想再带你去个地方，可以吗？这次不是什么旅游景点，恰恰相反，大概算是我的秘密据点。", "cleaned_lab_path": "F:/proj_dev/tmp/workdir4/data_prep/round1/firefly_mainstream/labels/chapter3_3_firefly_111.lab"}, "labels": {"has_text": true, "text_is_runtime_required": false}, "source_metadata": {"original_lab_path": "chapter3_3_firefly_111.lab", "cleaning_kept_punctuation": ["。", "，", "？"], "cleaning_removed_symbols": ["「", "」"]}}
{"record_id": "target::chapter3_17_firefly_116", "dataset": "firefly_round1_mainstream", "role": "target", "split": "train", "audio_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter3_17_firefly_116.wav", "audio": {"sample_rate": 44100, "channels": 1, "sample_width_bytes": 2, "duration_sec": 12.393991}, "text": {"raw": "…艾利欧总说命运只有一种，谁也无法绕开。他能看见未来，而我们…同样知晓自己「既定的结局」。", "clean": "，艾利欧总说命运只有一种，谁也无法绕开。他能看见未来，而我们，同样知晓自己既定的结局。", "cleaned_lab_path": "F:/proj_dev/tmp/workdir4/data_prep/round1/firefly_mainstream/labels/chapter3_17_firefly_116.lab"}, "labels": {"has_text": true, "text_is_runtime_required": false}, "source_metadata": {"original_lab_path": "chapter3_17_firefly_116.lab", "cleaning_kept_punctuation": ["。", "，"], "cleaning_removed_symbols": ["「", "」"]}}
{"record_id": "target::chapter3_3_firefly_209", "dataset": "firefly_round1_mainstream", "role": "target", "split": "train", "audio_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter3_3_firefly_209.wav", "audio": {"sample_rate": 44100, "channels": 1, "sample_width_bytes": 2, "duration_sec": 13.17898}, "text": {"raw": "我的故乡在很久以前就毁灭了，也许是军团干的，也可能是虫群…我是个星际难民，就和匹诺康尼的许多「本地人」一样。", "clean": "我的故乡在很久以前就毁灭了，也许是军团干的，也可能是虫群，我是个星际难民，就和匹诺康尼的许多本地人一样。", "cleaned_lab_path": "F:/proj_dev/tmp/workdir4/data_prep/round1/firefly_mainstream/labels/chapter3_3_firefly_209.lab"}, "labels": {"has_text": true, "text_is_runtime_required": false}, "source_metadata": {"original_lab_path": "chapter3_3_firefly_209.lab", "cleaning_kept_punctuation": ["。", "，"], "cleaning_removed_symbols": ["「", "」"]}}
{"record_id": "target::archive_firefly_17", "dataset": "firefly_round1_mainstream", "role": "target", "split": "train", "audio_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/archive_firefly_17.wav", "audio": {"sample_rate": 44100, "channels": 1, "sample_width_bytes": 2, "duration_sec": 13.557982}, "text": {"raw": "即便生命短暂，记忆也可永恒——也许很久以后，只要黑天鹅小姐还记得我，我在这个世界上的痕迹就不会消失。", "clean": "即便生命短暂，记忆也可永恒，也许很久以后，只要黑天鹅小姐还记得我，我在这个世界上的痕迹就不会消失。", "cleaned_lab_path": "F:/proj_dev/tmp/workdir4/data_prep/round1/firefly_mainstream/labels/archive_firefly_17.lab"}, "labels": {"has_text": true, "text_is_runtime_required": false}, "source_metadata": {"original_lab_path": "archive_firefly_17.lab", "cleaning_kept_punctuation": ["。", "，"], "cleaning_removed_symbols": []}}
{"record_id": "target::chapter3_2_firefly_218", "dataset": "firefly_round1_mainstream", "role": "target", "split": "train", "audio_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter3_2_firefly_218.wav", "audio": {"sample_rate": 44100, "channels": 1, "sample_width_bytes": 2, "duration_sec": 14.487982}, "text": {"raw": "他身高大约一米八上下，误差在两公分以内，体格健壮，明显锻炼过。步幅很长，但听不见踏地声，很轻巧。这种步法不会留下脚印……", "clean": "他身高大约一米八上下，误差在两公分以内，体格健壮，明显锻炼过。步幅很长，但听不见踏地声，很轻巧。这种步法不会留下脚印，", "cleaned_lab_path": "F:/proj_dev/tmp/workdir4/data_prep/round1/firefly_mainstream/labels/chapter3_2_firefly_218.lab"}, "labels": {"has_text": true, "text_is_runtime_required": false}, "source_metadata": {"original_lab_path": "chapter3_2_firefly_218.lab", "cleaning_kept_punctuation": ["。", "，"], "cleaning_removed_symbols": []}}
{"record_id": "target::chapter3_17_firefly_129", "dataset": "firefly_round1_mainstream", "role": "target", "split": "train", "audio_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter3_17_firefly_129.wav", "audio": {"sample_rate": 44100, "channels": 1, "sample_width_bytes": 2, "duration_sec": 15.477982}, "text": {"raw": "我果然还活着，且如我所想——抵达了与「美梦」截然不同的地方。匹诺康尼的梦境下埋藏着另一片更原始，也更混沌的忆域，它的名字是…「流放之地」。", "clean": "我果然还活着，且如我所想，抵达了与美梦截然不同的地方。匹诺康尼的梦境下埋藏着另一片更原始，也更混沌的忆域，它的名字是，流放之地。", "cleaned_lab_path": "F:/proj_dev/tmp/workdir4/data_prep/round1/firefly_mainstream/labels/chapter3_17_firefly_129.lab"}, "labels": {"has_text": true, "text_is_runtime_required": false}, "source_metadata": {"original_lab_path": "chapter3_17_firefly_129.lab", "cleaning_kept_punctuation": ["。", "，"], "cleaning_removed_symbols": ["「", "」"]}}
{"record_id": "target::chapter3_2_firefly_206", "dataset": "firefly_round1_mainstream", "role": "target", "split": "train", "audio_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter3_2_firefly_206.wav", "audio": {"sample_rate": 44100, "channels": 1, "sample_width_bytes": 2, "duration_sec": 16.697982}, "text": {"raw": "…我真的很感谢，你选择出手相助。也因此，我才能向你介绍这座乐园——它愿意接纳我，尽管我不属于这里。我也爱它，所以才想要…同别人分享。", "clean": "，我真的很感谢，你选择出手相助。也因此，我才能向你介绍这座乐园，它愿意接纳我，尽管我不属于这里。我也爱它，所以才想要，同别人分享。", "cleaned_lab_path": "F:/proj_dev/tmp/workdir4/data_prep/round1/firefly_mainstream/labels/chapter3_2_firefly_206.lab"}, "labels": {"has_text": true, "text_is_runtime_required": false}, "source_metadata": {"original_lab_path": "chapter3_2_firefly_206.lab", "cleaning_kept_punctuation": ["。", "，"], "cleaning_removed_symbols": []}}
{"record_id": "target::chapter3_4_firefly_106", "dataset": "firefly_round1_mainstream", "role": "target", "split": "train", "audio_path": "F:/proj_dev/tmp/workdir4/data_convert/dataset_firefly_raw/chapter3_4_firefly_106.wav", "audio": {"sample_rate": 44100, "channels": 1, "sample_width_bytes": 2, "duration_sec": 21.104989}, "text": {"raw": "但这里和我所熟知的「美梦」差别好大，幽闭…僻静…不安…还有这些飘浮的文字，你也能看见吧？家族治理下的匹诺康尼不可能会有这种地方。所以，是梦泡…？", "clean": "但这里和我所熟知的美梦差别好大，幽闭，僻静，不安，还有这些飘浮的文字，你也能看见吧？家族治理下的匹诺康尼不可能会有这种地方。所以，是梦泡，？", "cleaned_lab_path": "F:/proj_dev/tmp/workdir4/data_prep/round1/firefly_mainstream/labels/chapter3_4_firefly_106.lab"}, "labels": {"has_text": true, "text_is_runtime_required": false}, "source_metadata": {"original_lab_path": "chapter3_4_firefly_106.lab", "cleaning_kept_punctuation": ["。", "，", "？"], "cleaning_removed_symbols": ["「", "」"]}}
