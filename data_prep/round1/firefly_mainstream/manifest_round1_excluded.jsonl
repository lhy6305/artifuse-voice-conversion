{"id": "chapter4_7_firefly_111", "wav_path": "chapter4_7_firefly_111.wav", "original_lab_path": "chapter4_7_firefly_111.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_111.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 48000, "frame_count": 294096, "duration_sec": 6.127, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "这样吗…这一次同行，也会迎来戛然而止的时刻吗？", "cleaned": "这样吗，这一次同行，也会迎来戛然而止的时刻吗？", "kept_punctuation": ["，", "？"], "removed_symbols": [], "normalized_symbols": [{"from": "…", "to": "，"}]}, "include_in_round1": false, "exclusion_reasons": ["sample_rate=48000"]}
{"id": "chapter4_7_firefly_112", "wav_path": "chapter4_7_firefly_112.wav", "original_lab_path": "chapter4_7_firefly_112.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_112.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 48000, "frame_count": 740400, "duration_sec": 15.425, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "但…没关系。既然你出现在了这里，那就证明我们的道路还会交汇。你还活着，我也会活下去。尚未到来的分别不会是永别。", "cleaned": "但，没关系。既然你出现在了这里，那就证明我们的道路还会交汇。你还活着，我也会活下去。尚未到来的分别不会是永别。", "kept_punctuation": ["。", "，"], "removed_symbols": [], "normalized_symbols": [{"from": "…", "to": "，"}]}, "include_in_round1": false, "exclusion_reasons": ["sample_rate=48000"]}
{"id": "chapter4_7_firefly_113", "wav_path": "chapter4_7_firefly_113.wav", "original_lab_path": "chapter4_7_firefly_113.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_113.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 48000, "frame_count": 134784, "duration_sec": 2.808, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "那真是太好了。", "cleaned": "那真是太好了。", "kept_punctuation": ["。"], "removed_symbols": [], "normalized_symbols": []}, "include_in_round1": false, "exclusion_reasons": ["sample_rate=48000"]}
{"id": "chapter4_7_firefly_114", "wav_path": "chapter4_7_firefly_114.wav", "original_lab_path": "chapter4_7_firefly_114.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_114.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 48000, "frame_count": 134784, "duration_sec": 2.808, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "那真是太好了。", "cleaned": "那真是太好了。", "kept_punctuation": ["。"], "removed_symbols": [], "normalized_symbols": []}, "include_in_round1": false, "exclusion_reasons": ["sample_rate=48000"]}
{"id": "chapter4_7_firefly_115", "wav_path": "chapter4_7_firefly_115.wav", "original_lab_path": "chapter4_7_firefly_115.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_115.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 48000, "frame_count": 265584, "duration_sec": 5.533, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "嗯…不必说什么，你的眼睛已经给了我答案。", "cleaned": "嗯，不必说什么，你的眼睛已经给了我答案。", "kept_punctuation": ["。", "，"], "removed_symbols": [], "normalized_symbols": [{"from": "…", "to": "，"}]}, "include_in_round1": false, "exclusion_reasons": ["sample_rate=48000"]}
{"id": "chapter4_7_firefly_116", "wav_path": "chapter4_7_firefly_116.wav", "original_lab_path": "chapter4_7_firefly_116.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_116.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 48000, "frame_count": 503568, "duration_sec": 10.491, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "我会努力忘记这件事，把它封藏进脑海深处…等到分别的那一天，我会把你的话当作重聚的约定。", "cleaned": "我会努力忘记这件事，把它封藏进脑海深处，等到分别的那一天，我会把你的话当作重聚的约定。", "kept_punctuation": ["。", "，"], "removed_symbols": [], "normalized_symbols": [{"from": "…", "to": "，"}]}, "include_in_round1": false, "exclusion_reasons": ["sample_rate=48000"]}
{"id": "chapter4_7_firefly_117", "wav_path": "chapter4_7_firefly_117.wav", "original_lab_path": "chapter4_7_firefly_117.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_117.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 48000, "frame_count": 498912, "duration_sec": 10.394, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "当再次邂逅的那天到来，我想…我会假装我们素未谋面，再重新认识你一次，让一切都从头开始。", "cleaned": "当再次邂逅的那天到来，我想，我会假装我们素未谋面，再重新认识你一次，让一切都从头开始。", "kept_punctuation": ["。", "，"], "removed_symbols": [], "normalized_symbols": [{"from": "…", "to": "，"}]}, "include_in_round1": false, "exclusion_reasons": ["sample_rate=48000"]}
{"id": "chapter4_7_firefly_118", "wav_path": "chapter4_7_firefly_118.wav", "original_lab_path": "chapter4_7_firefly_118.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_118.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 48000, "frame_count": 401184, "duration_sec": 8.358, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "我还要尽最大的努力向你直抒胸襟…因为现在，我还做不到这点。", "cleaned": "我还要尽最大的努力向你直抒胸襟，因为现在，我还做不到这点。", "kept_punctuation": ["。", "，"], "removed_symbols": [], "normalized_symbols": [{"from": "…", "to": "，"}]}, "include_in_round1": false, "exclusion_reasons": ["sample_rate=48000"]}
{"id": "chapter4_7_firefly_119", "wav_path": "chapter4_7_firefly_119.wav", "original_lab_path": "chapter4_7_firefly_119.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_119.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 48000, "frame_count": 709008, "duration_sec": 14.771, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "真是值得期待的一天。两个人——不再是共犯，只是在银河间漂泊的两个灵魂——普普通通地相见，普普通通地相识……", "cleaned": "真是值得期待的一天。两个人，不再是共犯，只是在银河间漂泊的两个灵魂，普普通通地相见，普普通通地相识，", "kept_punctuation": ["。", "，"], "removed_symbols": [], "normalized_symbols": [{"from": "—", "to": "，"}, {"from": "—", "to": "，"}, {"from": "—", "to": "，"}, {"from": "—", "to": "，"}, {"from": "…", "to": "，"}, {"from": "…", "to": "，"}]}, "include_in_round1": false, "exclusion_reasons": ["sample_rate=48000"]}
{"id": "chapter4_7_firefly_120", "wav_path": "chapter4_7_firefly_120.wav", "original_lab_path": "chapter4_7_firefly_120.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_120.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 48000, "frame_count": 185184, "duration_sec": 3.858, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "…那就是我能够想象的，最大的奢侈。", "cleaned": "，那就是我能够想象的，最大的奢侈。", "kept_punctuation": ["。", "，"], "removed_symbols": [], "normalized_symbols": [{"from": "…", "to": "，"}]}, "include_in_round1": false, "exclusion_reasons": ["sample_rate=48000"]}
{"id": "chapter4_7_firefly_122", "wav_path": "chapter4_7_firefly_122.wav", "original_lab_path": "chapter4_7_firefly_122.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_122.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 48000, "frame_count": 543360, "duration_sec": 11.32, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "你要离开了，对吗？因为你要去做一件重要的事…你总是明白什么才是最重要的事。", "cleaned": "你要离开了，对吗？因为你要去做一件重要的事，你总是明白什么才是最重要的事。", "kept_punctuation": ["。", "，", "？"], "removed_symbols": [], "normalized_symbols": [{"from": "…", "to": "，"}]}, "include_in_round1": false, "exclusion_reasons": ["sample_rate=48000"]}
{"id": "chapter4_7_firefly_124", "wav_path": "chapter4_7_firefly_124.wav", "original_lab_path": "chapter4_7_firefly_124.lab", "cleaned_lab_path": "labels/chapter4_7_firefly_124.lab", "wav": {"channels": 1, "sample_width_bytes": 2, "sample_rate": 48000, "frame_count": 204624, "duration_sec": 4.263, "compression_type": "NONE", "compression_name": "not compressed"}, "text": {"raw": "希望那是一个有流星划过的美丽夜晚。", "cleaned": "希望那是一个有流星划过的美丽夜晚。", "kept_punctuation": ["。"], "removed_symbols": [], "normalized_symbols": []}, "include_in_round1": false, "exclusion_reasons": ["sample_rate=48000"]}
